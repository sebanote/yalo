{
  "name": "yalo",
  "version": "1.0.0",
  "description": "E2E Testing Framework with Playwright and Typescript",
  "main": "index.js",
  "author": "",
  "license": "ISC",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "cross-env HEADED=1 npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "test:chrome": "npx playwright test --project=chromium",
    "report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^20.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
